---
interface Review {
  platform: string;
  score: string;
  scale?: string;
  label: string;
}

interface Props {
  eyebrow: string;
  reviews: Review[];
}

const { eyebrow, reviews } = Astro.props;
---
<section class="reviews-bar" aria-label={eyebrow}>
  <div class="wrap reviews-inner">
    <span class="eyebrow">{eyebrow}</span>
    <div class="reviews-list">
      {reviews.map((r) => (
        <div class="review">
          <span class="review-platform">{r.platform}</span>
          <span class="review-score">
            <strong>{r.score}</strong>
            {r.scale && <span class="review-scale">{r.scale}</span>}
          </span>
          <span class="review-label">{r.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>
