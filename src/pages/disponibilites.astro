---
import '../styles/global.css';
import Brand from '../components/Brand.astro';
import { asset, base } from '../utils/paths';
import { buildMonths, loadBookedDates } from '../utils/calendar';

const whatsapp = 'https://wa.me/41795362242?text=Bonjour%20Jeevan%20Palm%2C%20je%20souhaite%20r%C3%A9server%20la%20villa.';

const { booked, fetchOk } = await loadBookedDates();
const monthNames = ['Janvier', 'Février', 'Mars', 'Avril', 'Mai', 'Juin', 'Juillet', 'Août', 'Septembre', 'Octobre', 'Novembre', 'Décembre'];
const { months, now } = buildMonths(booked, monthNames);
const updated = new Intl.DateTimeFormat('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' }).format(now);
---
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Disponibilités — Jeevan Palm</title>
  <meta name="description" content="Calendrier des disponibilités de la villa Jeevan Palm à l'île Maurice." />
  <meta name="robots" content="index,follow" />
</head>
<body class="page-cal">
  <header class="subhead">
    <nav class="nav nav-solid">
      <Brand href={base} />
      <div class="nav-right">
        <div class="navlinks"><a href={base}>← Retour au site</a></div>
        <div class="lang"><a href={asset('disponibilites')} class="on">FR</a><span class="sep">·</span><a href={asset('en/availability')}>EN</a></div>
      </div>
    </nav>
  </header>

  <section class="section cal-hero">
    <div class="wrap">
      <span class="eyebrow">Réservation</span>
      <h1>Disponibilités</h1>
      <p>Consultez les dates libres et réservez directement avec nous. Le calendrier est synchronisé avec Booking et notre agenda.</p>
      <div class="legend">
        <span class="lg"><i class="sw sw-free"></i> Disponible</span>
        <span class="lg"><i class="sw sw-booked"></i> Occupé</span>
      </div>
      {!fetchOk && <p class="cal-warn">Le calendrier n’a pas pu être chargé pour le moment. Contactez-nous directement pour connaître les disponibilités.</p>}
      <div class="actions">
        <a class="btn btn-solid" href={whatsapp} target="_blank" rel="noopener">Réserver sur WhatsApp</a>
      </div>
    </div>
  </section>

  <section class="section cal-section">
    <div class="wrap">
      <div class="cal-grid">
        {months.map((mo) => (
          <div class="cal-month">
            <h3>{mo.label}</h3>
            <div class="cal-dow"><span>Lu</span><span>Ma</span><span>Me</span><span>Je</span><span>Ve</span><span>Sa</span><span>Di</span></div>
            <div class="cal-days">
              {mo.cells.map((c) => (
                c ? <span class={`day${c.booked ? ' booked' : ''}${c.past ? ' past' : ''}`}>{c.day}</span> : <span class="empty"></span>
              ))}
            </div>
          </div>
        ))}
      </div>
      <p class="cal-updated">Dernière mise à jour : {updated}</p>
    </div>
  </section>

  <section class="cta">
    <span class="eyebrow">Jeevan Palm · Île Maurice</span>
    <h2>Une date vous plaît ? Réservons-la.</h2>
    <div class="actions" style="justify-content:center">
      <a class="btn btn-light" href={whatsapp} target="_blank" rel="noopener">Écrire sur WhatsApp</a>
      <a class="btn btn-outline" href={base}>Revenir au site</a>
    </div>
  </section>

  <footer class="footer">
    <div class="wrap footer-grid">
      <div>
        <Brand href={base} />
        <p style="margin:.4rem 0 0">Villa privée · Côte ouest · Île Maurice</p>
      </div>
      <div>
        <p style="margin:0">Contact<br /><a href={whatsapp} target="_blank" rel="noopener">Écrire sur WhatsApp</a></p>
      </div>
    </div>
  </footer>

  <a class="floating" href={whatsapp} target="_blank" rel="noopener">WhatsApp</a>
</body>
</html>
